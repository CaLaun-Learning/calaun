# CaLaun environment variables. Copy to .env for local dev:
#   cp .env.example .env
# In production, set these in your host's environment (Railway, Fly, Render, etc.).

# === Django core ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-64-char-random-string

# Set to False in production
DEBUG=True

# Comma-separated. Include your apex + www host in production.
# Examples: localhost,127.0.0.1   |   calaun.example.org,www.calaun.example.org
ALLOWED_HOSTS=127.0.0.1,localhost

# Required in production when using forms over HTTPS. Comma-separated, include scheme.
# Example: https://calaun.example.org,https://www.calaun.example.org
CSRF_TRUSTED_ORIGINS=

# === Database ===
# Production: set DATABASE_URL (Postgres). Leave blank locally to fall back to SQLite.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# === Chatbot (Groq) ===
# Free key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override default model
# GROQ_MODEL=llama-3.1-8b-instant

# === HTTPS / security (only honored when DEBUG=False) ===
# Set False if your host terminates TLS upstream and you don't want Django to redirect.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# === Logging ===
LOG_LEVEL=INFO
